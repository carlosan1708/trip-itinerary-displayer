{
  "hosting": {
    "target": "main",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/agent/**", "run": { "serviceId": "agent", "region": "us-central1" } },
      { "source": "/auth/**",  "run": { "serviceId": "agent", "region": "us-central1" } },
      { "source": "/demo/**",  "run": { "serviceId": "agent", "region": "us-central1" } },
      { "source": "/health",   "run": { "serviceId": "agent", "region": "us-central1" } },
      { "source": "**",        "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
