{
  "hosting": {
    "target": "main",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/agent/**", "run": { "serviceId": "agent", "region": "us-central1" } },
      { "source": "/auth/**",  "run": { "serviceId": "agent", "region": "us-central1" } },
      { "source": "/health",   "run": { "serviceId": "agent", "region": "us-central1" } },
      { "source": "**",        "destination": "/index.html" }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
