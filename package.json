{
  "name": "trip-itinerary",
  "description": "React + Vite SPA for shared travel itinerary management with Firebase Auth, Firestore sync, and role-based access control",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/carlosan1708/trip-itinerary-displayer.git"
  },
  "scripts": {
    "dev": "vite",
    "dev:test": "vite --mode test --port 5174",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "sync:status": "node --env-file=.env scripts/sync-data.mjs --status",
    "sync:upload": "node --env-file=.env scripts/sync-data.mjs --upload",
    "sync:download": "node --env-file=.env scripts/sync-data.mjs --download",
    "sync": "node --env-file=.env scripts/sync-data.mjs --sync",
    "sync:pull-registry": "node --env-file=.env scripts/sync-data.mjs --pull-registry",
    "sync:push-registry": "node --env-file=.env scripts/sync-data.mjs --push-registry",
    "seed:demo": "node scripts/seed-demo.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^5.16.0",
    "@mui/material": "^5.16.0",
    "@react-pdf/renderer": "^4.4.1",
    "firebase": "^12.12.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "firebase-admin": "^13.8.0",
    "jsdom": "^25.0.1",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
