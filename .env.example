VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_ADMIN_EMAIL=tu@email.com
VITE_TRIP_ID=canada-2026

# ── Demo mode (anonymous "try it" sandbox) ───────────────────────────
# Separate Firestore gateway/registry namespace for demo trips. Demo users
# never touch the real VITE_TRIP_ID data. Enable Anonymous Auth in the
# Firebase Console (Authentication → Sign-in method → Anonymous).
VITE_DEMO_TRIP_ID=demo-gateway
# Cloudflare Turnstile site key (public). The value below is Cloudflare's
# official always-passes TEST key — replace with your real site key in prod.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Per-demo-user caps (client UX; backend/rules are the real source of truth)
VITE_DEMO_MAX_TRIPS=2
VITE_DEMO_MAX_AI_CALLS=100

# ── Test / dev user (email+password login) ───────────────────────────
# Run: node scripts/create-test-user.mjs  to provision this user in Firebase Auth
VITE_TEST_EMAIL=test@example.com
VITE_TEST_PASSWORD=changeme123

# Direct backend base URL — bypasses Firebase Hosting CDN (required for SSE streaming).
# Firebase Hosting buffers all responses, so SSE never reaches the browser through it.
# Preferred: Cloud Run service base, e.g. https://agent-XXXXXXXX-uc.a.run.app
# Also supported: legacy URL ending in /agent, e.g. https://...cloudfunctions.net/agent
# Leave empty or unset in local dev — Vite proxy handles /agent/** → localhost:8000.
VITE_AGENT_URL=https://agent-XXXXXXXX-uc.a.run.app

# ── Sync script (scripts/sync-data.mjs) ──────────────────────────────
# Archivo local que representa el VITE_TRIP_ID en Firestore
LOCAL_TRIP_FILE=src/data/canada/canada-trip.json

# Credenciales Admin SDK — una de las dos opciones:
# Opción A: ruta al service account JSON (Firebase Console > Configuración > Cuentas de servicio)
GOOGLE_APPLICATION_CREDENTIALS=/ruta/absoluta/service-account.json
# Opción B: contenido del JSON en una sola línea (útil para CI)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Backend demo mode ────────────────────────────────────────────────
# Cloudflare Turnstile secret key (verified server-side at /demo/start).
# Value below is Cloudflare's official always-passes TEST secret — replace
# in prod. Get keys at https://dash.cloudflare.com → Turnstile.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# Must match VITE_DEMO_TRIP_ID — the demo gateway/registry namespace.
DEMO_TRIP_ID=demo-gateway
# Per-demo-user AI interaction cap enforced in the backend.
DEMO_MAX_AI_CALLS=100
