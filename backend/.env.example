# Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Path to Firebase service account JSON (for token verification)
# Download from Firebase Console → Project Settings → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccount.json

# Admin email — user who receives the admin custom claim on first login
ADMIN_EMAIL=you@example.com

# Frontend origin for CORS (production: your Firebase Hosting URL)
# Default when unset: http://localhost:5173
FRONTEND_ORIGIN=https://your-project.web.app
